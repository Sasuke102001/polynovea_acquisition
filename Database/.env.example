# Polynovea Module 2 — Database Environment Variables
# Copy this file to .env and fill in your AWS RDS credentials
# Never commit .env to version control

# AWS RDS PostgreSQL — ap-south-1 (Mumbai), db.t3.micro, Single-AZ
# Endpoint format: your-db-instance.xxxxxxxxxxxx.ap-south-1.rds.amazonaws.com
PG_HOST=your-db-instance.xxxxxxxxxxxx.ap-south-1.rds.amazonaws.com
PG_PORT=5432
PG_DB=polynovea_module2
PG_USER=polynovea_admin
PG_PASSWORD=your_strong_password
